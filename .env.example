# ============================================================
# CVGen Backend — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS commiter le fichier .env sur Git !
# ============================================================

# Base de données PostgreSQL
# Format : postgresql://utilisateur:motdepasse@hote:port/nom_bdd
DATABASE_URL=postgresql://postgres:motdepasse@localhost:5432/cvgen_db

# Clé secrète JWT (générer avec : openssl rand -hex 32)
SECRET_KEY=changez_cette_cle_par_une_valeur_aleatoire_longue

# Algorithme JWT (ne pas modifier)
ALGORITHM=HS256

# Durée de validité du token en minutes (60 = 1 heure)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Clé API Anthropic (Claude)
# Obtenir sur : https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-votre-cle-ici
